{
  "manifest_version": 3,
  "name": "MANGHO detector",
  "version": "0.1.0",
  "description": "게임 마이너 갤러리의 게임 참가 스팀링크를 탐지하고 참가 편의성을 향상시키는 확장프로그램",
  
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  
  "host_permissions": [
    "https://gall.dcinside.com/*",
    "https://steamcommunity.com/*"
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "background": {
    "service_worker": "scripts/background.js"
  },
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MANGHO detector 설정"
  },
  
  "content_scripts": [
    {
      "matches": [
        "*://*.dcinside.com/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "https://gall.dcinside.com/*"
      ]
    }
  ]
}